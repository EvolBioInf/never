  "paths": {
    "/accessions": {
      "get": {
        "summary": "Get accession levels",
        "tags": [
          "Accession"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Accession"
                  }
                },
                "examples": {
                  "Example": {
                    "value": [
                      {
                        "accession": "GCF_000001405.40",
                        "level": "chromosome"
                      },
                      {
                        "accession": "GCA_000002115.2",
                        "level": "chromosome"
                      }
                    ]
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing required parameter."
          }
        },
        "operationId": "get-accessions",
        "parameters": [
          {
            "schema": {
              "type": "array",
              "example": [
                "GCF_000001405.40",
                "GCA_000002115.2"
              ],
              "items": {
                "type": "string"
              }
            },
            "in": "query",
            "name": "accession_ids",
            "description": "IDs of accessions to filter for",
            "explode": false,
            "style": "form",
            "required": true
          },
          {
            "$ref": "#/components/parameters/page"
          },
          {
            "$ref": "#/components/parameters/page_size"
          }
        ],
        "description": "Get accessions and their levels filtered by accession IDs"
      }
    },
    "/assembly-levels": {
