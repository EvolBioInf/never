        "operationId": "get-taxa",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "dolph"
            },
            "in": "query",
            "name": "name",
            "description": "Name or pattern of the taxa",
            "required": true
          },
          {
            "schema": {
              "type": "boolean"
            },
            "in": "query",
            "name": "scientific",
            "description": "Whether to search in scientific names only"
          },
          {
            "schema": {
              "type": "boolean"
            },
            "in": "query",
            "name": "exact",
            "description": "Whether to search for exactly that name or use the name as a pattern"
          },
          {
            "schema": {
              "type": "integer",
              "example": 2,
              "default": 0,
              "minimum": 0
            },
            "in": "query",
            "name": "page",
            "description": "Current page"
          },
          {
            "schema": {
              "type": "integer",
              "example": 10,
              "default": -1,
              "minimum": -1
            },
            "in": "query",
            "name": "page_size",
            "description": "Amount of entries per page"
          }
        ],
        "description": "Get basic taxon data for taxa with the given name"
      }
    },
